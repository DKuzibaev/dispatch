---
export interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;

const categories = [
  { label: 'World', href: '/category/world' },
  { label: 'Technology', href: '/category/technology' },
  { label: 'Business', href: '/category/business' },
  { label: 'Science', href: '/category/science' },
  { label: 'Culture', href: '/category/culture' },
  { label: 'Opinion', href: '/category/opinion' },
];
---

<header class="site-header">
  <!-- Top bar -->
  <div class="header-top">
    <div class="container header-top-inner">
      <div class="header-date" id="header-date"></div>
      <a href="/" class="header-logo">
        <span class="logo-the">The</span>
        <span class="logo-dispatch">Dispatch</span>
      </a>
      <div class="header-actions">
        <button class="search-toggle" aria-label="Search" id="search-toggle">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
        <button class="theme-toggle" aria-label="Toggle theme" id="theme-toggle">
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>
    </div>
  </div>
  <hr class="divider" />

  <!-- Nav -->
  <nav class="header-nav">
    <div class="container header-nav-inner">
      {categories.map(cat => (
        <a
          href={cat.href}
          class={`nav-link ${currentPath.startsWith(cat.href) ? 'active' : ''}`}
        >{cat.label}</a>
      ))}
    </div>
  </nav>
  <hr class="divider" />

  <!-- Search overlay -->
  <div class="search-overlay" id="search-overlay">
    <div class="container search-inner">
      <form class="search-form" id="search-form" action="/search">
        <input
          type="text"
          name="q"
          class="search-input"
          placeholder="Search articles, authors, topics..."
          autocomplete="off"
          id="search-input"
        />
        <button type="submit" class="search-submit">Search</button>
        <button type="button" class="search-close" id="search-close">✕</button>
      </form>
    </div>
  </div>
</header>

<style>
.site-header { background: var(--bg); position: sticky; top: 0; z-index: 100; }

/* Top bar */
.header-top { padding: 20px 0 16px; }
.header-top-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 24px;
}
.header-date {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text-3);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.header-logo {
  text-align: center;
  text-decoration: none;
  display: block;
  line-height: 1;
}
.logo-the {
  display: block;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 2px;
}
.logo-dispatch {
  display: block;
  font-family: var(--serif);
  font-size: clamp(28px, 4vw, 44px);
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.02em;
  line-height: 1;
}
.header-actions {
  display: flex;
  align-items: center;
  gap: 16px;
  justify-content: flex-end;
}
.search-toggle, .theme-toggle {
  background: none; border: none; cursor: pointer;
  color: var(--text-3); padding: 6px;
  display: flex; align-items: center;
  transition: color 0.2s;
}
.search-toggle:hover, .theme-toggle:hover { color: var(--text); }
.icon-moon { display: none; }
[data-theme="dark"] .icon-sun { display: none; }
[data-theme="dark"] .icon-moon { display: block; }

/* Nav */
.header-nav { padding: 0; }
.header-nav-inner {
  display: flex;
  align-items: center;
  gap: 0;
  overflow-x: auto;
  scrollbar-width: none;
}
.header-nav-inner::-webkit-scrollbar { display: none; }
.nav-link {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-2);
  text-decoration: none;
  padding: 12px 16px;
  white-space: nowrap;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}
.nav-link:hover { color: var(--text); border-bottom-color: var(--border); }
.nav-link.active { color: var(--accent); border-bottom-color: var(--accent); }

/* Search overlay */
.search-overlay {
  display: none;
  padding: 20px 0;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
}
.search-overlay.open { display: block; }
.search-form {
  display: flex;
  align-items: center;
  gap: 12px;
}
.search-input {
  flex: 1;
  background: none;
  border: none;
  border-bottom: 2px solid var(--border);
  padding: 8px 0;
  font-family: var(--serif);
  font-size: 20px;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s;
}
.search-input::placeholder { color: var(--text-3); }
.search-input:focus { border-bottom-color: var(--accent); }
.search-submit {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--accent);
  color: white;
  border: none;
  padding: 8px 20px;
  cursor: pointer;
  transition: background 0.2s;
}
.search-submit:hover { background: var(--accent-dark); }
.search-close {
  background: none; border: none;
  color: var(--text-3); cursor: pointer;
  font-size: 16px; padding: 8px;
  transition: color 0.2s;
}
.search-close:hover { color: var(--text); }

@media (max-width: 768px) {
  .header-date { display: none; }
  .header-top-inner { grid-template-columns: auto 1fr; }
  .header-actions { order: -1; }
}
</style>
