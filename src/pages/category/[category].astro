---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const categories = [
    "world",
    "technology",
    "business",
    "science",
    "culture",
    "opinion",
  ];
  return categories.map((cat) => ({
    params: { category: cat },
    props: { categoryName: cat.charAt(0).toUpperCase() + cat.slice(1) },
  }));
}

const { category } = Astro.params;
const { categoryName } = Astro.props;

const allArticles = await getCollection("articles");
const catArticles = allArticles
  .filter(
    (a: CollectionEntry<"articles">) =>
      a.data.category.toLowerCase() === category,
  )
  .sort(
    (a: CollectionEntry<"articles">, b: CollectionEntry<"articles">) =>
      b.data.date.valueOf() - a.data.date.valueOf(),
  );

const hero = catArticles[0];
const rest = catArticles.slice(1);
---

<Layout title={`${categoryName} — The Dispatch`}>
  <Header currentPath={`/category/${category}`} />
  <main>
    <div class="cat-header">
      <div class="container">
        <div class="cat-header-inner fade-up">
          <span class="cat-label">Section</span>
          <h1 class="cat-title">{categoryName}</h1>
          <span class="cat-count">{catArticles.length} articles</span>
        </div>
      </div>
    </div>
    <hr class="divider" />

    <div class="cat-content">
      <div class="container">
        {
          hero ? (
            <>
              <div class="cat-hero fade-up">
                <ArticleCard
                  slug={hero.slug}
                  title={hero.data.title}
                  excerpt={hero.data.excerpt}
                  category={hero.data.category}
                  author={hero.data.author}
                  authorSlug={hero.data.authorSlug}
                  date={hero.data.date.toISOString()}
                  readTime={hero.data.readTime}
                  image={hero.data.image}
                  size="large"
                  featured={true}
                />
              </div>
              {rest.length > 0 && (
                <div class="cat-grid">
                  {rest.map((a) => (
                    <ArticleCard
                      slug={a.slug}
                      title={a.data.title}
                      excerpt={a.data.excerpt}
                      category={a.data.category}
                      author={a.data.author}
                      authorSlug={a.data.authorSlug}
                      date={a.data.date.toISOString()}
                      readTime={a.data.readTime}
                      image={a.data.image}
                    />
                  ))}
                </div>
              )}
            </>
          ) : (
            <div class="empty-state">
              <p>No articles in this category yet.</p>
              <a href="/" class="back-link">
                ← Back to home
              </a>
            </div>
          )
        }
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .cat-header {
    padding: 48px 0 36px;
  }
  .cat-header-inner {
    display: flex;
    align-items: baseline;
    gap: 20px;
  }
  .cat-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .cat-title {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .cat-count {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-3);
    margin-left: auto;
  }
  .cat-content {
    padding: 48px 0;
  }
  .cat-hero {
    margin-bottom: 1px;
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-light);
  }
  .empty-state {
    text-align: center;
    padding: 80px 0;
  }
  .empty-state p {
    font-size: 1.1rem;
    color: var(--text-2);
    margin-bottom: 20px;
  }
  .back-link {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
  }
  @media (max-width: 768px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
    .cat-header-inner {
      flex-wrap: wrap;
    }
  }
</style>
