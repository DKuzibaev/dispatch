---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Contact — The Dispatch"
  description="Get in touch with The Dispatch editorial team."
>
  <Header />
  <main>
    <div class="page-header">
      <div class="container-narrow">
        <div class="page-label fade-up">Contact</div>
        <h1 class="page-title fade-up">Get in touch.</h1>
        <p class="page-sub fade-up">
          We read every message. We can't always reply, but we try.
        </p>
      </div>
    </div>

    <hr class="divider" />

    <div class="page-body">
      <div class="container contact-grid">
        <!-- Contact form -->
        <div class="form-col fade-up">
          <form class="contact-form" id="contact-form">
            <div class="form-group">
              <label class="form-label" for="name">Your name</label>
              <input
                type="text"
                id="name"
                name="name"
                class="form-input"
                placeholder="Jane Smith"
                required
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="email">Email address</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                placeholder="jane@example.com"
                required
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="subject">Subject</label>
              <select id="subject" name="subject" class="form-select">
                <option value="">Select a topic...</option>
                <option value="tip">News tip or story idea</option>
                <option value="correction">Correction request</option>
                <option value="press">Press inquiry</option>
                <option value="advertising">Advertising</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="message">Message</label>
              <textarea
                id="message"
                name="message"
                class="form-textarea"
                rows="6"
                placeholder="Tell us what's on your mind..."
                required></textarea>
            </div>
            <button type="submit" class="form-submit">Send Message</button>
          </form>
          <div class="form-success" id="form-success">
            <div class="success-icon">✓</div>
            <h3>Message sent</h3>
            <p>We'll get back to you within 2 business days.</p>
          </div>
        </div>

        <!-- Contact info -->
        <div class="info-col fade-up">
          <div class="contact-card">
            <div class="contact-card-title">Editorial</div>
            <p class="contact-card-text">
              Story tips, corrections, press inquiries, and editorial feedback.
            </p>
            <a href="mailto:editors@thedispatch.com" class="contact-email"
              >editors@thedispatch.com</a
            >
          </div>
          <div class="contact-card">
            <div class="contact-card-title">Corrections</div>
            <p class="contact-card-text">
              We correct errors promptly. Please include the article URL.
            </p>
            <a href="mailto:corrections@thedispatch.com" class="contact-email"
              >corrections@thedispatch.com</a
            >
          </div>
          <div class="contact-card">
            <div class="contact-card-title">Advertising</div>
            <p class="contact-card-text">
              Partnership and sponsorship inquiries.
            </p>
            <a href="mailto:advertising@thedispatch.com" class="contact-email"
              >advertising@thedispatch.com</a
            >
          </div>
          <div class="contact-card">
            <div class="contact-card-title">Secure Tips</div>
            <p class="contact-card-text">
              For sensitive tips, use Signal or our SecureDrop instance.
            </p>
            <span class="contact-email" style="color:var(--text-3)"
              >Signal: +1 (555) 000-0000</span
            >
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document
    .getElementById("contact-form")
    .addEventListener("submit", function (e) {
      e.preventDefault();
      this.style.display = "none";
      document.getElementById("form-success").style.display = "flex";
    });
</script>

<style>
  .container-narrow {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .page-header {
    padding: 64px 0 48px;
  }
  .page-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 20px;
  }
  .page-title {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }
  .page-sub {
    font-size: 1rem;
    color: var(--text-2);
  }
  .page-body {
    padding: 48px 0 80px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 80px;
    align-items: start;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .form-input,
  .form-select,
  .form-textarea {
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 12px 16px;
    font-family: var(--body);
    font-size: 0.95rem;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    border-color: var(--accent);
  }
  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--text-3);
  }
  .form-textarea {
    resize: vertical;
    min-height: 140px;
    font-family: var(--body);
  }
  .form-select {
    appearance: none;
    cursor: pointer;
  }
  .form-submit {
    background: var(--accent);
    color: white;
    border: none;
    padding: 14px 32px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
    align-self: flex-start;
  }
  .form-submit:hover {
    background: var(--accent-dark);
  }

  .form-success {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 0;
    gap: 12px;
  }
  .success-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }
  .form-success h3 {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 700;
  }
  .form-success p {
    color: var(--text-2);
    font-size: 0.9rem;
  }

  /* Info */
  .info-col {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .contact-card {
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--border-light);
  }
  .contact-card-title {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .contact-card-text {
    font-size: 0.85rem;
    color: var(--text-2);
    line-height: 1.6;
    margin-bottom: 10px;
  }
  .contact-email {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
    word-break: break-all;
  }
  .contact-email:hover {
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
  @media (max-width: 768px) {
    .container-narrow {
      padding: 0 20px;
    }
    .contact-grid {
      padding: 0 20px;
    }
  }
</style>
