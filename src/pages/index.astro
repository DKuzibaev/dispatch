---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const allArticles = (await getCollection("articles")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const featured = allArticles.filter((a) => a.data.featured);
const hero = featured[0] ?? allArticles[0];
const secondFeatured = featured[1] ?? allArticles[1];
const latest = allArticles.filter((a) => !a.data.featured).slice(0, 6);
const opinionPieces = allArticles.filter((a) => a.data.category === "Opinion");
const scienceArticles = allArticles.filter(
  (a) => a.data.category === "Science",
);
---

<Layout>
  <Header currentPath="/" />
  <main>
    <section class="hero-feature">
      <div class="container">
        <div class="hero-grid">
          <article class="hero-main fade-up">
            <a href={`/article/${hero.slug}`} class="hero-image-link">
              <div class="hero-image-wrap">
                <img
                  src={hero.data.image}
                  alt={hero.data.title}
                  class="hero-image"
                />
                <div class="hero-image-overlay"></div>
              </div>
            </a>
            <div class="hero-content">
              <a
                href={`/category/${hero.data.category.toLowerCase()}`}
                class="category-badge">{hero.data.category}</a
              >
              <h1 class="hero-title">
                <a href={`/article/${hero.slug}`}>{hero.data.title}</a>
              </h1>
              <p class="hero-excerpt">{hero.data.excerpt}</p>
              <div class="meta hero-meta">
                <a href={`/author/${hero.data.authorSlug}`}
                  >{hero.data.author}</a
                >
                <span class="meta-dot">·</span>
                <time
                  >{
                    hero.data.date.toLocaleDateString("en-US", {
                      month: "long",
                      day: "numeric",
                      year: "numeric",
                    })
                  }</time
                >
                <span class="meta-dot">·</span>
                <span>{hero.data.readTime} min read</span>
              </div>
            </div>
          </article>
          <div class="hero-sidebar fade-up">
            <article>
              <a href={`/article/${secondFeatured.slug}`}>
                <img
                  src={secondFeatured.data.image}
                  alt={secondFeatured.data.title}
                  class="sidebar-image"
                />
              </a>
              <a
                href={`/category/${secondFeatured.data.category.toLowerCase()}`}
                class="category-badge">{secondFeatured.data.category}</a
              >
              <h2 class="sidebar-title">
                <a href={`/article/${secondFeatured.slug}`}
                  >{secondFeatured.data.title}</a>
              </h2>
              <div class="meta">
                <a href={`/author/${secondFeatured.data.authorSlug}`}
                  >{secondFeatured.data.author}</a
                >
                <span class="meta-dot">·</span>
                <span>{secondFeatured.data.readTime} min read</span>
              </div>
            </article>
            <hr class="divider" />
            <div class="most-read">
              <div class="section-label">Most Read</div>
              {
                allArticles.slice(2, 6).map((a, i) => (
                  <a href={`/article/${a.slug}`} class="most-read-item">
                    <span class="most-read-num">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <span class="most-read-title">{a.data.title}</span>
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <div class="ticker-wrap">
      <div class="container ticker-inner">
        <span class="ticker-label">Latest</span>
        <div class="ticker-track">
          <div class="ticker-content">
            {
              [...allArticles, ...allArticles].map((a) => (
                <a href={`/article/${a.slug}`} class="ticker-item">
                  <span class="ticker-cat">{a.data.category}</span>
                  {a.data.title}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <hr class="divider" />

    <section class="section-latest">
      <div class="container">
        <div class="section-header-row">
          <div class="section-label-lg">Latest Stories</div>
          <a href="/category/world" class="view-all">View all →</a>
        </div>
        <div class="latest-grid">
          {
            latest.map((a) => (
              <ArticleCard
                slug={a.slug}
                title={a.data.title}
                excerpt={a.data.excerpt}
                category={a.data.category}
                author={a.data.author}
                authorSlug={a.data.authorSlug}
                date={a.data.date.toISOString()}
                readTime={a.data.readTime}
                image={a.data.image}
              />
            ))
          }
        </div>
      </div>
    </section>

    <div class="container">
      <div class="divider-ornament"><span>◆ ◆ ◆</span></div>
    </div>

    <section class="section-two-col">
      <div class="container two-col-grid">
        <div class="col-section">
          <div class="section-header-row">
            <div class="section-label-lg">Opinion</div>
            <a href="/category/opinion" class="view-all">More →</a>
          </div>
          <div class="col-articles">
            {
              opinionPieces.map((a) => (
                <article class="list-article fade-up">
                  <a
                    href={`/category/${a.data.category.toLowerCase()}`}
                    class="category-badge"
                  >
                    {a.data.category}
                  </a>
                  <h3 class="list-title">
                    <a href={`/article/${a.slug}`}>{a.data.title}</a>
                  </h3>
                  <p class="list-excerpt">{a.data.excerpt}</p>
                  <div class="meta">
                    <a href={`/author/${a.data.authorSlug}`}>{a.data.author}</a>
                    <span class="meta-dot">·</span>
                    <span>{a.data.readTime} min read</span>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
        <div class="col-divider"></div>
        <div class="col-section">
          <div class="section-header-row">
            <div class="section-label-lg">Science</div>
            <a href="/category/science" class="view-all">More →</a>
          </div>
          <div class="col-articles">
            {
              scienceArticles.map((a) => (
                <article class="list-article fade-up">
                  <a
                    href={`/category/${a.data.category.toLowerCase()}`}
                    class="category-badge"
                  >
                    {a.data.category}
                  </a>
                  <h3 class="list-title">
                    <a href={`/article/${a.slug}`}>{a.data.title}</a>
                  </h3>
                  <p class="list-excerpt">{a.data.excerpt}</p>
                  <div class="meta">
                    <a href={`/author/${a.data.authorSlug}`}>{a.data.author}</a>
                    <span class="meta-dot">·</span>
                    <span>{a.data.readTime} min read</span>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section-newsletter">
      <div class="container">
        <div class="newsletter-box fade-up">
          <div class="newsletter-ornament">◆</div>
          <h2 class="newsletter-title">The Dispatch Daily</h2>
          <p class="newsletter-sub">
            Get our editors' picks delivered every morning. Concise,
            independent, essential.
          </p>
          <form class="newsletter-form">
            <input
              type="email"
              placeholder="your@email.com"
              class="newsletter-input"
              required
            />
            <button type="submit" class="newsletter-btn">Subscribe</button>
          </form>
          <p class="newsletter-note">
            No spam. Unsubscribe anytime. Read by 40,000+ subscribers.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero-feature {
    padding: 48px 0 40px;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 40px;
    align-items: start;
  }
  .hero-image-wrap {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    margin-bottom: 24px;
  }
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .hero-main:hover .hero-image {
    transform: scale(1.02);
  }
  .hero-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.15), transparent);
  }
  .hero-title {
    font-family: var(--serif);
    font-size: clamp(26px, 3.5vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 10px 0 16px;
  }
  .hero-title a {
    text-decoration: none;
    color: var(--text);
  }
  .hero-title a:hover {
    color: var(--accent);
  }
  .hero-excerpt {
    font-size: 1rem;
    color: var(--text-2);
    line-height: 1.7;
    margin-bottom: 16px;
    max-width: 600px;
  }
  .hero-sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .sidebar-image {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    margin-bottom: 16px;
    display: block;
  }
  .sidebar-title {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 8px 0 10px;
  }
  .sidebar-title a {
    text-decoration: none;
    color: var(--text);
  }
  .sidebar-title a:hover {
    color: var(--accent);
  }
  .section-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 16px;
  }
  .most-read {
    display: flex;
    flex-direction: column;
  }
  .most-read-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-light);
    text-decoration: none;
    color: var(--text);
    transition: color 0.2s;
  }
  .most-read-item:last-child {
    border-bottom: none;
  }
  .most-read-item:hover {
    color: var(--accent);
  }
  .most-read-num {
    font-family: var(--mono);
    font-size: 16px;
    font-weight: 500;
    color: var(--border);
    flex-shrink: 0;
    line-height: 1.4;
  }
  .most-read-title {
    font-family: var(--serif);
    font-size: 0.85rem;
    line-height: 1.4;
    font-weight: 500;
  }
  .ticker-wrap {
    padding: 10px 0;
    background: var(--bg2);
    overflow: hidden;
  }
  .ticker-inner {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .ticker-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ticker-track {
    overflow: hidden;
    flex: 1;
  }
  .ticker-content {
    display: flex;
    animation: ticker 45s linear infinite;
    width: max-content;
  }
  .ticker-item {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-2);
    text-decoration: none;
    white-space: nowrap;
    padding: 0 32px;
    border-right: 1px solid var(--border);
    transition: color 0.2s;
  }
  .ticker-item:hover {
    color: var(--accent);
  }
  .ticker-cat {
    color: var(--accent);
    margin-right: 8px;
  }
  .ticker-track:hover .ticker-content {
    animation-play-state: paused;
  }
  @keyframes ticker {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .section-latest {
    padding: 60px 0;
  }
  .section-header-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--text);
  }
  .section-label-lg {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .view-all {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
  }
  .view-all:hover {
    color: var(--accent-dark);
  }
  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-light);
  }
  .divider-ornament {
    text-align: center;
    position: relative;
    margin: 40px 0;
  }
  .divider-ornament::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border);
    transform: translateY(-50%);
  }
  .divider-ornament span {
    position: relative;
    background: var(--bg);
    padding: 0 16px;
    color: var(--text-3);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
  }
  .section-two-col {
    padding: 0 0 60px;
  }
  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 48px;
  }
  .col-divider {
    background: var(--border-light);
  }
  .col-articles {
    display: flex;
    flex-direction: column;
  }
  .list-article {
    padding: 24px 0;
    border-bottom: 1px solid var(--border-light);
  }
  .list-article:last-child {
    border-bottom: none;
  }
  .list-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 8px 0 10px;
  }
  .list-title a {
    text-decoration: none;
    color: var(--text);
  }
  .list-title a:hover {
    color: var(--accent);
  }
  .list-excerpt {
    font-size: 0.82rem;
    color: var(--text-2);
    line-height: 1.6;
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .section-newsletter {
    padding: 40px 0 80px;
  }
  .newsletter-box {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    padding: 60px 48px;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .newsletter-ornament {
    font-size: 12px;
    color: var(--accent);
    margin-bottom: 20px;
    letter-spacing: 0.3em;
  }
  .newsletter-title {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }
  .newsletter-sub {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.6;
    margin-bottom: 28px;
  }
  .newsletter-form {
    display: flex;
    gap: 0;
    margin-bottom: 14px;
  }
  .newsletter-input {
    flex: 1;
    padding: 12px 16px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-right: none;
    font-family: var(--body);
    font-size: 0.9rem;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }
  .newsletter-input:focus {
    border-color: var(--accent);
  }
  .newsletter-input::placeholder {
    color: var(--text-3);
  }
  .newsletter-btn {
    padding: 12px 24px;
    background: var(--accent);
    color: white;
    border: none;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .newsletter-btn:hover {
    background: var(--accent-dark);
  }
  .newsletter-note {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-sidebar {
      display: none;
    }
    .latest-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .two-col-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .col-divider {
      display: none;
    }
  }
  @media (max-width: 600px) {
    .latest-grid {
      grid-template-columns: 1fr;
    }
    .newsletter-box {
      padding: 40px 24px;
    }
    .newsletter-form {
      flex-direction: column;
    }
    .newsletter-input {
      border-right: 1px solid var(--border);
    }
  }
</style>
